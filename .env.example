# ============================================
# BiscoFootball AI Automation — Environment Template
# Rename this file to `.env` and fill in your credentials.
# ============================================

# --- Telegram ---
# Create a bot via BotFather and copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your personal chat ID or channel ID where the bot should notify you and accept commands
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Instagram (Meta Graph API) ---
# Requires a Meta Developer account, App with Graph API access, and page access tokens
INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_api_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# --- YouTube ---
# Path to the OAuth client secret JSON file for uploading Shorts
YOUTUBE_CLIENT_SECRET_PATH=client_secret.json

# --- ChatGPT Playwright ---
# Account credentials for automating ChatGPT via Playwright if login helper is not run
CHATGPT_EMAIL=your_chatgpt_email_here
CHATGPT_PASSWORD=your_chatgpt_password_here

# --- Football API (api-football.com) ---
# Sign up at api-sports.io to get a free API key for football statistics and matches
FOOTBALL_API_KEY=your_football_api_key_here

# --- Scoring ---
# Minimal ChatGPT score needed to trigger the rest of the generation/publishing pipeline
VIRAL_SCORE_THRESHOLD=7.0
# Global toggles (can also be configured in config.py)
ENABLE_INSTAGRAM_UPLOAD=True
